{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:patch-diff.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:docs.vllm.ai)",
      "WebFetch(domain:docs.sglang.io)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:code.claude.com)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com"
      ]
    },
    "enableWeakerNetworkIsolation": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "light-daltonized",
  "skipAutoPermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.tmux/claude-status idle" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.tmux/claude-status busy" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.tmux/claude-status wait" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$HOME/.tmux/claude-status idle" }
        ]
      }
    ]
  }
}
